# Akeneo PIM Configuration
#
# Option 1: Run `make start` to automatically create .env and populate these values interactively
# Option 2: Manually copy this file to .env and fill in your actual values

# Your Akeneo PIM host URL (without trailing slash)
PIM_HOST=https://your-instance.cloud.akeneo.com

# OAuth2 Client Credentials
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Extension App User Credentials
USERNAME=your_app_username_here
PASSWORD=your_app_password_here

# API Authentication Tokens (generated via OAuth2 flow)
API_TOKEN=your_api_token_here
REFRESH_TOKEN=your_refresh_token_here
TOKEN_CREATED_AT=0

# Extension UUID (generated when extension is created)
EXTENSION_UUID=your_extension_uuid_here
